# Spring Boot API
VITE_API_URL="http://localhost:8080/api/v1"
VITE_WS_URL="http://localhost:8080/ws"

# Google Login
VITE_GOOGLE_CLIENT_ID="your_google_client_id"

# Analytics
VITE_POSTHOG_KEY=""
VITE_POSTHOG_HOST="https://us.i.posthog.com"
# Dùng cho nút "Mở PostHog" trong admin dashboard (không phải secret).
# Số liệu dashboard query qua backend proxy (POSTHOG_PERSONAL_KEY ở Chiptrip-be/.env).
VITE_POSTHOG_API_HOST="https://us.posthog.com"
VITE_POSTHOG_PROJECT_ID=""

# Supabase Configuration
VITE_SUPABASE_PROJECT_ID="your_project_id"
VITE_SUPABASE_PUBLISHABLE_KEY="your_supabase_publishable_key"
VITE_SUPABASE_URL="https://your_project_id.supabase.co"
# Goong Maps
# REST API (Direction/DistanceMatrix/Geocode) đã proxy qua BE — chỉ cần Maptiles token để render map JS.
VITE_GOONG_MAPTILES_KEY="your_goong_maptiles_key"
